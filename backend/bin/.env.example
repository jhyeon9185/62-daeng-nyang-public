# DB (로컬 MySQL)
DB_USERNAME=root
DB_PASSWORD=your_password

# 공공데이터 API (선택) - 15098931 구조동물조회 활용신청 후 발급
# GET URL용 → Encoding 키(%,%2F,%3D 포함) 사용. 500 시 Decoding↔Encoding 바꿔 시도.
DATA_API_KEY=your_encoding_key
# base-url (선택)
# PUBLIC_API_BASE_URL=https://apis.data.go.kr/15098931


# Resend Email
RESEND_API_KEY=re_xxxxxxxx
# 도메인 인증 후(예: playw.work): 해당 도메인 발신 주소로 설정하면 어떤 수신자에게든 발송 가능
# RESEND_FROM_EMAIL=noreply@playw.work
# 참고: 기본 발신(onboarding@resend.dev) 사용 시 Resend 계정에 등록된 이메일로만 수신 가능. 관리자 알림이 안 오면 수신 주소를 Resend 로그인 이메일과 동일하게 하거나, 도메인 인증 후 RESEND_FROM_EMAIL 설정.
# 이메일 헤더 로고 이미지 URL (선택)
# RESEND_LOGO_URL=https://your-domain.com/logo.png

# 프론트엔드 URL (이메일 내 '관리자 로그인 바로가기' 링크용, 운영 시 실제 도메인으로 설정)
# FRONTEND_URL=https://your-domain.com